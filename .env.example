# ============================================================================
# frontend-v1 (landing Skipfee) — variables de entorno
#
# ⚠️ La landing es ESTÁTICA (output:'export'). Las NEXT_PUBLIC_* se incrustan EN
#    EL BUILD (`npm run build`), NO en runtime. Por eso deben estar presentes al
#    buildear (en Cloudflare: Settings → Build → Variables and secrets).
#    No hay secretos acá: el form /pre-registro postea al BACKEND, que es quien
#    guarda en Supabase y avisa a Discord.
# ============================================================================

# Dominio real del sitio (afecta OG, canonical, sitemap, robots). Default: https://skipfee.co
NEXT_PUBLIC_SITE_URL=https://skipfee.co

# --- Tracking de visitantes: Cloudflare Web Analytics ---
# Cloudflare dashboard → Web Analytics → (agregá tu sitio) → "Manual" → copiá el "token".
# Sin esto, el beacon (static.cloudflareinsights.com/beacon.min.js) NO se inyecta.
NEXT_PUBLIC_CF_BEACON_TOKEN=

# --- (Opcional) Google Search Console ---
# Método "Etiqueta HTML": pegá el valor `content` de la meta google-site-verification.
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# --- Captura de leads (formulario /pre-registro → backend) ---
# Origen del backend (SkipFee-backend). El form hace POST a {API_URL}/api/leads.
# Sin esto, el form corre en modo demo (no guarda). Acordate de agregar el dominio
# de esta landing a EXTRA_CORS_ORIGINS en el backend para que su CORS te deje postear.
# Ej local: http://localhost:3000  ·  prod: https://api.skipfee.co
NEXT_PUBLIC_API_URL=

# --- (Opcional) Modo demo del panel (/onboarding) ---
# Origen del panel admin para el botón "Ver mi panel de prueba" del onboarding.
# El wizard redirige a {ADMIN_URL}/preview/dashboard?demo=1&negocio=...&plan=...
# Default: https://admin.skipfee.co  ·  dev local: http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=

# --- (Opcional) CTAs de contacto ---
# Número de WhatsApp del negocio, solo dígitos (ej. 573001234567) — botones wa.me.
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Link "Agendar mi llamada" (Google Calendar Appointment Schedule o Calendly).
NEXT_PUBLIC_CALENDAR_URL=
